# Medical Assistant + Open WebUI Environment Configuration

# Database Configuration
POSTGRES_DB=chatapp_db
POSTGRES_USER=chatapp
POSTGRES_PASSWORD=chatapp_password

# Open WebUI Configuration
WEBUI_SECRET_KEY=medical_assistant_secret_key_change_this_in_production
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=user

# API Configuration
MEDICAL_ASSISTANT_API_URL=http://localhost:8000
OPEN_WEBUI_URL=http://localhost:3000

# Security Settings
NGINX_RATE_LIMIT=10r/m
SESSION_TIMEOUT=3600

# Development vs Production
ENVIRONMENT=development