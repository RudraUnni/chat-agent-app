# Application Settings
APP_NAME="Chat Agent API"
APP_VERSION="1.0.0"
DEBUG=false

# OpenRouter Configuration (Primary)
OPENROUTER_API_KEY=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
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# These are set automatically by runtime.py from OPENROUTER_API_KEY
# Don't modify these unless you know what you're doing
OPENAI_API_KEY=${OPENROUTER_API_KEY}
OPENAI_BASE_URL=${OPENROUTER_BASE_URL}

DEFAULT_LLM_PROVIDER=openrouter
DEFAULT_LLM_MODEL=openai/gpt-4o-mini

# API Configuration
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# PubMed API
PUBMED_MAX_RESULTS=5
PUBMED_TIMEOUT=15