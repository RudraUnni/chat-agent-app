# Open WebUI Environment Configuration
# Copy this to .env file and update with your actual values

# Core Configuration
WEBUI_SECRET_KEY=your-super-secret-key-change-this
WEBUI_NAME=Medical Assistant Pro
WEBUI_DESCRIPTION=AI-powered medical consultation platform with research capabilities

# Branding & UI
WEBUI_TITLE=Medical Assistant Pro
WEBUI_LOGO_URL=https://img.icons8.com/color/96/000000/stethoscope.png
WEBUI_FAVICON_URL=https://img.icons8.com/color/96/000000/stethoscope.png
WEBUI_PRIMARY_COLOR=#2563eb
WEBUI_SECONDARY_COLOR=#1e40af
WEBUI_ACCENT_COLOR=#3b82f6

# Ollama Integration (if you want to use local models)
OLLAMA_BASE_URL=http://host.docker.internal:11434
ENABLE_OLLAMA=true

# OpenAI API Integration
ENABLE_OPENAI_API=true
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Authentication & Security
ENABLE_SIGNUP=false
ENABLE_LOGIN_FORM=true
ENABLE_OAUTH=false
ENABLE_HEADERS_AUTH=false
ENABLE_SESSION=true
SESSION_EXPIRE_TIME=86400

# Features
ENABLE_RAG=true
ENABLE_VOICE=true
ENABLE_IMAGE_GENERATION=true
ENABLE_WEB_SEARCH=true
ENABLE_WEB_BROWSING=true
ENABLE_FUNCTION_CALLING=true

# RAG Configuration
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_EMBEDDING_MODEL=text-embedding-ada-002

# Default Models
DEFAULT_MODELS=gpt-3.5-turbo,medical-assistant

# Database 
DATABASE_URL=postgresql://chatapp:chatapp_password@postgres:5432/chatapp_db

# Logging
LOG_LEVEL=INFO
ENABLE_DEBUG=false

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Medical Assistant Specific
MEDICAL_ASSISTANT_ENABLED=true
MEDICAL_WORKFLOW_URL=http://backend:8000
MEDICAL_API_ENDPOINT=http://backend:8000/api/v1/chat
