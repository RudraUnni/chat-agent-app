{
  "medical_assistant_models": [
    {
      "id": "medical-assistant",
      "name": "Medical Assistant",
      "description": "AI-powered medical research assistant with PubMed integration",
      "api_base": "http://host.docker.internal:8000/api/v1/openwebui",
      "api_key": "medical-assistant-key",
      "model_type": "openai",
      "capabilities": {
        "chat": true,
        "streaming": true,
        "function_calling": false,
        "vision": false
      },
      "parameters": {
        "temperature": 0.7,
        "max_tokens": 2000,
        "top_p": 0.9
      },
      "medical_features": {
        "pubmed_integration": true,
        "evidence_based": true,
        "citation_support": true,
        "medical_terminology": true
      }
    },
