# Open WebUI Configuration
WEBUI_SECRET_KEY=your-medical-assistant-secret-key-change-this-in-production
WEBUI_AUTH=false
DEFAULT_MODELS=medical-assistant
ENABLE_SIGNUP=true
ENABLE_LOGIN_FORM=true
WEBUI_NAME=Medical Assistant Chat
WEBUI_URL=http://localhost:3001
ENABLE_COMMUNITY_SHARING=false
ENABLE_MESSAGE_RATING=true
ENABLE_MODEL_FILTER=true

# Your FastAPI Backend Configuration
FASTAPI_BASE_URL=http://backend:8000
FASTAPI_API_ENDPOINT=/api/v1/chat
FASTAPI_WORKFLOW=pubmed_research
FASTAPI_API_KEY=

# Database for chat history (Open WebUI uses SQLite by default)
# Open WebUI will automatically create and manage its own database
DATABASE_URL=sqlite:///data/webui.db

# Optional: If you want to use PostgreSQL for Open WebUI as well
# DATABASE_URL=postgresql://chatapp:chatapp_password@postgres:5432/openwebui_db

# Pipeline Configuration
PIPELINE_MEDICAL_ENABLED=true
PIPELINE_PDF_ENABLED=true

# Security Settings
CORS_ALLOW_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Logging
LOG_LEVEL=INFO